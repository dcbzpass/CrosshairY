<Window x:Class="CrosshairY.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="760" Height="600"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        Opacity="0"
        RenderOptions.BitmapScalingMode="HighQuality"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Border x:Name="OuterBorder" CornerRadius="0" Background="#080808"
            BorderBrush="#1e1e1e" BorderThickness="1"
            ClipToBounds="True">
        <Grid ClipToBounds="True">

            <Grid x:Name="StartupGrid" Background="#080808" Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="20,0,0,0">
                    <TextBlock x:Name="AsciiText"
                               Text="Welcome."
                               FontFamily="{StaticResource BebasNeue}"
                               FontSize="96"
                               Foreground="#f5f5f5"
                               HorizontalAlignment="Center"
                               Opacity="0"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <Rectangle x:Name="AccentLine"
                               Height="1" Width="0"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0"
                               Fill="#f5f5f5"
                               Opacity="0.25"/>
                    <TextBlock x:Name="StatusText"
                               FontFamily="{StaticResource IBMPlexMono}"
                               FontSize="11"
                               Foreground="#787878"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0"
                               Opacity="0"
                               Text=""/>
                </StackPanel>
            </Grid>

            <Border x:Name="MainGrid" Visibility="Collapsed"
                    Background="Transparent" Panel.ZIndex="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#080808"
                            BorderBrush="#1e1e1e"
                            BorderThickness="0,0,0,1"
                            MouseLeftButtonDown="TitleBar_MouseDown">
                        <Grid Margin="18,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="CrosshairY"
                                           FontFamily="{StaticResource IBMPlexMono}"
                                           FontSize="13"
                                           Foreground="#f5f5f5"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" v1.0.6"
                                           FontFamily="{StaticResource IBMPlexMono}"
                                           FontSize="9"
                                           Foreground="#2a2a2a"
                                           VerticalAlignment="Center"
                                           Margin="10,1,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="—"
                                        Style="{StaticResource TitleIconBtn}"
                                        FontFamily="{StaticResource IBMPlexMono}"
                                        FontSize="12"
                                        Click="Minimize_Click"/>
                                <Button Style="{StaticResource TitleCloseBtn}"
                                        Margin="1,0,0,0"
                                        Click="Close_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#080808"
                                BorderBrush="#1e1e1e"
                                BorderThickness="0,0,1,0">
                            <StackPanel Margin="0,20,0,0">
                                <TextBlock Text="MAIN"
                                           FontFamily="{StaticResource IBMPlexMono}"
                                           FontSize="9"
                                           Foreground="#787878"
                                           Margin="16,0,0,6"/>
                                <Button x:Name="BtnCrosshairs"
                                        Content="Crosshairs"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnCrosshairs_Click"/>
                                <Button x:Name="BtnProfiles"
                                        Content="Profiles"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnProfiles_Click"/>
                                <Button x:Name="BtnBuilder"
                                        Content="Builder"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnBuilder_Click"/>
                                <Button x:Name="BtnSettings"
                                        Content="Settings"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnSettings_Click"/>
                                <Button x:Name="BtnSupport"
                                        Content="Support"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnSupport_Click"/>
                                <Rectangle Height="1" Margin="16,28,16,0" Fill="#1e1e1e"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer x:Name="MainScrollViewer"
                                      Grid.Column="1"
                                      Background="#080808"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="0,0,2,0">
                            <Grid>

                                <StackPanel x:Name="CrosshairsPanel" Margin="28,24,28,28">

                                    <TextBlock Text="CROSSHAIRS"
                                               FontFamily="{StaticResource BebasNeue}"
                                               FontSize="38"
                                               Foreground="#f5f5f5"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="Configure your persistent screen crosshair overlay"
                                               FontFamily="{StaticResource IBMPlexMono}"
                                               FontSize="10"
                                               Foreground="#787878"
                                               Margin="0,0,0,18"/>
                                    <Rectangle Height="1" Fill="#1e1e1e" Margin="0,0,0,18"/>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="TEMPLATE"
                                                           FontFamily="{StaticResource BebasNeue}"
                                                           FontSize="18"
                                                           Foreground="#f5f5f5"
                                                           VerticalAlignment="Center"/>
                                                <Button Content="RANDOMIZE"
                                                        Style="{StaticResource DarkBtn}"
                                                        HorizontalAlignment="Right"
                                                        Width="90"
                                                        Click="Randomize_Click"/>
                                            </Grid>
                                            <TextBlock Text="Click a style to select it — click again to deselect"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9"
                                                       Foreground="#787878"
                                                       Margin="0,0,0,14"/>
                                            <WrapPanel x:Name="CrTemplatePanel"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="CustomTemplateBorder"
                                            BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10"
                                            Visibility="Collapsed">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="MY CROSSHAIRS"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Crosshairs you saved from the Builder — click to use, × to delete"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9"
                                                       Foreground="#787878"
                                                       Margin="0,0,0,14"/>
                                            <WrapPanel x:Name="CustomTemplatePanel"/>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="OPTIONS"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,14"/>

                                            <TextBlock Text="COLOR"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"
                                                       Margin="0,0,0,8"/>
                                            <WrapPanel x:Name="CrColorPanel" Margin="0,0,0,8"/>
                                            <Button x:Name="CrCustomColorBtn"
                                                    Content="CUSTOM COLOR"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,16"
                                                    Click="OpenColorPicker_Click"/>
                                            <Popup x:Name="ColorPickerPopup"
                                                   StaysOpen="False"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade"
                                                   Placement="Bottom"
                                                   PlacementTarget="{Binding ElementName=CrCustomColorBtn}"
                                                   VerticalOffset="4">
                                                <Border Background="#0f0f0f"
                                                        BorderBrush="#1e1e1e"
                                                        BorderThickness="1"
                                                        Padding="14"
                                                        Width="228">
                                                    <StackPanel>
                                                        <Grid x:Name="SvSquare"
                                                              Width="200" Height="150"
                                                              ClipToBounds="True"
                                                              Cursor="Cross"
                                                              Background="Transparent"
                                                              MouseLeftButtonDown="SvSquare_MouseDown"
                                                              MouseMove="SvSquare_MouseMove"
                                                              MouseLeftButtonUp="SvSquare_MouseUp">
                                                            <Rectangle x:Name="SvHueRect"/>
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Offset="0" Color="#FFFFFFFF"/>
                                                                        <GradientStop Offset="1" Color="#00FFFFFF"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                        <GradientStop Offset="0" Color="#00000000"/>
                                                                        <GradientStop Offset="1" Color="#FF000000"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Canvas>
                                                                <Ellipse x:Name="SvThumb"
                                                                         Width="12" Height="12"
                                                                         Stroke="#f5f5f5"
                                                                         StrokeThickness="2"
                                                                         IsHitTestVisible="False"/>
                                                            </Canvas>
                                                        </Grid>

                                                        <Grid x:Name="HueBar"
                                                              Width="200" Height="14"
                                                              Margin="0,12,0,0"
                                                              ClipToBounds="True"
                                                              Cursor="Cross"
                                                              Background="Transparent"
                                                              MouseLeftButtonDown="HueBar_MouseDown"
                                                              MouseMove="HueBar_MouseMove"
                                                              MouseLeftButtonUp="HueBar_MouseUp">
                                                            <Rectangle>
                                                                <Rectangle.Fill>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Offset="0.00" Color="#FF0000"/>
                                                                        <GradientStop Offset="0.17" Color="#FFFF00"/>
                                                                        <GradientStop Offset="0.33" Color="#00FF00"/>
                                                                        <GradientStop Offset="0.50" Color="#00FFFF"/>
                                                                        <GradientStop Offset="0.67" Color="#0000FF"/>
                                                                        <GradientStop Offset="0.83" Color="#FF00FF"/>
                                                                        <GradientStop Offset="1.00" Color="#FF0000"/>
                                                                    </LinearGradientBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Canvas>
                                                                <Rectangle x:Name="HueThumb"
                                                                           Width="4" Height="14"
                                                                           Fill="#00000000"
                                                                           Stroke="#f5f5f5"
                                                                           StrokeThickness="2"
                                                                           IsHitTestVisible="False"/>
                                                            </Canvas>
                                                        </Grid>

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border x:Name="PickerPreview"
                                                                    Grid.Column="0"
                                                                    Width="30" Height="30"
                                                                    BorderBrush="#1e1e1e"
                                                                    BorderThickness="1"
                                                                    Margin="0,0,8,0"/>
                                                            <TextBox x:Name="PickerHexInput"
                                                                     Grid.Column="1"
                                                                     Style="{StaticResource DarkEntry}"
                                                                     MaxLength="9"
                                                                     VerticalAlignment="Center"
                                                                     TextChanged="PickerHexInput_Changed"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>

                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,0,0,1"
                                                    Margin="0,0,0,14" Padding="0,0,0,14">
                                                <Grid>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="OUTLINE"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#f5f5f5"/>
                                                        <TextBlock Text="Draw a dark outline behind the crosshair shape"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" Foreground="#787878"
                                                                   Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="CrOutlineToggle"
                                                                  Style="{StaticResource ToggleSwitch}"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  Checked="CrToggle_Changed"
                                                                  Unchecked="CrToggle_Changed"/>
                                                </Grid>
                                            </Border>

                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="OUTLINE THICKNESS"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" Foreground="#787878"/>
                                                <TextBlock x:Name="CrOutlineSizeLabel"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="#f5f5f5"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="CrOutlineSizeSlider"
                                                    Style="{StaticResource DarkSlider}"
                                                    Minimum="1" Maximum="5" Value="1"
                                                    Margin="0,0,0,16"
                                                    ValueChanged="CrOutlineSizeSlider_Changed"/>

                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="SIZE (%)"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" Foreground="#787878"/>
                                                <TextBlock x:Name="CrSizeLabel"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="#f5f5f5"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="CrSizeSlider"
                                                    Style="{StaticResource DarkSlider}"
                                                    Minimum="50" Maximum="200" Value="100"
                                                    Margin="0,0,0,16"
                                                    ValueChanged="CrSizeSlider_Changed"/>

                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="OPACITY (%)"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" Foreground="#787878"/>
                                                <TextBlock x:Name="CrOpacityLabel"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="#f5f5f5"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="CrOpacitySlider"
                                                    Style="{StaticResource DarkSlider}"
                                                    Minimum="10" Maximum="100" Value="100"
                                                    Margin="0,0,0,16"
                                                    ValueChanged="CrOpacitySlider_Changed"/>

                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="CENTER GAP"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" Foreground="#787878"/>
                                                <TextBlock x:Name="CrGapLabel"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="#f5f5f5"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="CrGapSlider"
                                                    Style="{StaticResource DarkSlider}"
                                                    Minimum="0" Maximum="20" Value="3"
                                                    ValueChanged="CrGapSlider_Changed"/>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="POSITION"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Nudge the crosshair off-center, or have it follow your cursor"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"
                                                       Margin="0,0,0,14"/>

                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,0,0,1"
                                                    Margin="0,0,0,14" Padding="0,0,0,14">
                                                <Grid>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="FOLLOW CURSOR"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#f5f5f5"/>
                                                        <TextBlock Text="Replace the cursor with your crosshair — hides the centered one"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" Foreground="#787878"
                                                                   Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="CrFollowToggle"
                                                                  Style="{StaticResource ToggleSwitch}"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  Checked="CrFollowToggle_Changed"
                                                                  Unchecked="CrFollowToggle_Changed"/>
                                                </Grid>
                                            </Border>

                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="OFFSET X"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" Foreground="#787878"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <RepeatButton Content="−"
                                                                  Style="{StaticResource DarkRepeatBtn}"
                                                                  Tag="x-"
                                                                  Click="CrPosNudge_Click"/>
                                                    <TextBlock x:Name="CrPosXLabel"
                                                               Text="0"
                                                               Width="54"
                                                               TextAlignment="Center"
                                                               FontFamily="{StaticResource IBMPlexMono}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="#f5f5f5"
                                                               VerticalAlignment="Center"/>
                                                    <RepeatButton Content="+"
                                                                  Style="{StaticResource DarkRepeatBtn}"
                                                                  Tag="x+"
                                                                  Click="CrPosNudge_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,0,0,14">
                                                <TextBlock Text="OFFSET Y"
                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                           FontSize="9" Foreground="#787878"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <RepeatButton Content="−"
                                                                  Style="{StaticResource DarkRepeatBtn}"
                                                                  Tag="y-"
                                                                  Click="CrPosNudge_Click"/>
                                                    <TextBlock x:Name="CrPosYLabel"
                                                               Text="0"
                                                               Width="54"
                                                               TextAlignment="Center"
                                                               FontFamily="{StaticResource IBMPlexMono}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="#f5f5f5"
                                                               VerticalAlignment="Center"/>
                                                    <RepeatButton Content="+"
                                                                  Style="{StaticResource DarkRepeatBtn}"
                                                                  Tag="y+"
                                                                  Click="CrPosNudge_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <Button Content="RESET POSITION"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Click="CrPosReset_Click"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <StackPanel x:Name="ProfilesPanel" Margin="28,24,28,28" Visibility="Collapsed">

                                    <TextBlock Text="PROFILES"
                                               FontFamily="{StaticResource BebasNeue}"
                                               FontSize="38"
                                               Foreground="#f5f5f5"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="Configs are stored in %APPDATA%\CrosshairY — drop a friend's .json in there and reload"
                                               FontFamily="{StaticResource IBMPlexMono}"
                                               FontSize="10"
                                               Foreground="#787878"
                                               Margin="0,0,0,18"
                                               TextWrapping="Wrap"/>
                                    <Rectangle Height="1" Fill="#1e1e1e" Margin="0,0,0,18"/>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="SAVE CURRENT"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,14"/>
                                            <TextBlock Text="NAME"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"
                                                       Margin="0,0,0,5"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="ProfileNameBox"
                                                         Grid.Column="0"
                                                         Style="{StaticResource DarkEntry}"
                                                         Text="my config"/>
                                                <Button Grid.Column="2"
                                                        Content="SAVE"
                                                        Style="{StaticResource DarkBtn}"
                                                        Click="SaveProfile_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="CLIPBOARD SHARE"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Export copies a code to your clipboard. Import reads it and saves using the name above."
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9"
                                                       Foreground="#787878"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,14"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="EXPORT"
                                                        Style="{StaticResource DarkBtn}"
                                                        Click="ExportProfile_Click"/>
                                                <Button Grid.Column="2"
                                                        Content="IMPORT"
                                                        Style="{StaticResource DarkBtn}"
                                                        Click="ImportProfile_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <Grid Margin="0,0,0,14">
                                                <TextBlock Text="SAVED CONFIGS"
                                                           FontFamily="{StaticResource BebasNeue}"
                                                           FontSize="18"
                                                           Foreground="#f5f5f5"
                                                           VerticalAlignment="Center"/>
                                                <Button Content="RELOAD"
                                                        Style="{StaticResource DarkBtn}"
                                                        HorizontalAlignment="Right"
                                                        Width="70"
                                                        Click="ReloadProfiles_Click"/>
                                            </Grid>
                                            <StackPanel x:Name="ProfileListPanel"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <StackPanel x:Name="BuilderPanel" Margin="28,24,28,28" Visibility="Collapsed">

                                    <TextBlock Text="BUILDER"
                                               FontFamily="{StaticResource BebasNeue}"
                                               FontSize="38"
                                               Foreground="#f5f5f5"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="Draw your own crosshair with brush, shape and fill tools"
                                               FontFamily="{StaticResource IBMPlexMono}"
                                               FontSize="10"
                                               Foreground="#787878"
                                               Margin="0,0,0,18"/>
                                    <Rectangle Height="1" Fill="#1e1e1e" Margin="0,0,0,18"/>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="PALETTE"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,10"/>
                                            <WrapPanel x:Name="BuilderPalettePanel" Margin="0,0,0,12"/>

                                            <TextBlock x:Name="BuilderModeLabel"
                                                       Text="tool: pencil  #ffffff"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9"
                                                       Foreground="#787878"
                                                       Margin="0,0,0,12"/>

                                            <TextBlock Text="GRID SIZE"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"
                                                       Margin="0,0,0,6"/>
                                            <StackPanel x:Name="BuilderSizePanel" Orientation="Horizontal" Margin="0,0,0,12">
                                                <Button Content="15×15"
                                                        Style="{StaticResource DarkBtn}"
                                                        Width="60" Margin="0,0,6,0"
                                                        Tag="15"
                                                        Click="BuilderGridSize_Click"/>
                                                <Button Content="30×30"
                                                        Style="{StaticResource DarkBtn}"
                                                        Width="60" Margin="0,0,6,0"
                                                        Tag="30"
                                                        Click="BuilderGridSize_Click"/>
                                                <Button Content="60×60"
                                                        Style="{StaticResource DarkBtn}"
                                                        Width="60"
                                                        Tag="60"
                                                        Click="BuilderGridSize_Click"/>
                                            </StackPanel>

                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="64"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="64"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="BuilderMirrorBtn"
                                                        Grid.Column="0"
                                                        Content="MIRROR: OFF"
                                                        Style="{StaticResource DarkBtn}"
                                                        Click="BuilderMirror_Click"/>
                                                <Button x:Name="BuilderUndoBtn"
                                                        Grid.Column="2"
                                                        Content="UNDO"
                                                        Style="{StaticResource DarkBtn}"
                                                        Click="BuilderUndo_Click"/>
                                                <Button x:Name="BuilderRedoBtn"
                                                        Grid.Column="4"
                                                        Content="REDO"
                                                        Style="{StaticResource DarkBtn}"
                                                        Click="BuilderRedo_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="CANVAS"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Click or drag to paint. The overlay updates live as you draw."
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9"
                                                       Foreground="#787878"
                                                       Margin="0,0,0,14"/>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <StackPanel x:Name="BuilderToolPanel" Margin="0,0,14,0">
                                                    <Button Style="{StaticResource BuilderToolBtn}" Tag="Pencil" Click="BuilderTool_Click" ToolTip="Pencil">
                                                        <Path Data="M3,17 L13,7 L17,11 L7,21 L3,21 Z M13,7 L15,5 L17,7 L15,9 Z"
                                                              Stroke="#cfcfcf" StrokeThickness="1.4" Fill="Transparent"
                                                              StrokeLineJoin="Round" Width="22" Height="22" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Style="{StaticResource BuilderToolBtn}" Tag="Eraser" Click="BuilderTool_Click" ToolTip="Eraser">
                                                        <Path Data="M5,15 L13,7 L19,13 L13,19 L8,19 Z M8,19 L13,19"
                                                              Stroke="#cfcfcf" StrokeThickness="1.4" Fill="Transparent"
                                                              StrokeLineJoin="Round" Width="22" Height="22" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Style="{StaticResource BuilderToolBtn}" Tag="Fill" Click="BuilderTool_Click" ToolTip="Fill">
                                                        <Path Data="M5,11 L11,5 L19,13 L13,19 L7,19 Z M19,14 C19,17 22,17 22,14 C22,12 20.5,11 20.5,11 C20.5,11 19,12.5 19,14 Z"
                                                              Stroke="#cfcfcf" StrokeThickness="1.3" Fill="Transparent"
                                                              StrokeLineJoin="Round" Width="22" Height="22" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Style="{StaticResource BuilderToolBtn}" Tag="Line" Click="BuilderTool_Click" ToolTip="Line">
                                                        <Path Data="M4,20 L20,4"
                                                              Stroke="#cfcfcf" StrokeThickness="1.6"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                              Width="22" Height="22" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Style="{StaticResource BuilderToolBtn}" Tag="Rect" Click="BuilderTool_Click" ToolTip="Rectangle">
                                                        <Rectangle Width="18" Height="14" Stroke="#cfcfcf" StrokeThickness="1.6" Fill="Transparent"/>
                                                    </Button>
                                                    <Button Style="{StaticResource BuilderToolBtn}" Tag="Ellipse" Click="BuilderTool_Click" ToolTip="Ellipse">
                                                        <Ellipse Width="18" Height="16" Stroke="#cfcfcf" StrokeThickness="1.6" Fill="Transparent"/>
                                                    </Button>
                                                    <Button Style="{StaticResource BuilderToolBtn}" Click="BuilderClear_Click" ToolTip="Clear">
                                                        <Path Data="M5,7 L19,7 M9,7 L9,5 L15,5 L15,7 M7,7 L8,20 L16,20 L17,7 M10,10 L10,17 M14,10 L14,17"
                                                              Stroke="#cf6a6a" StrokeThickness="1.4" Fill="Transparent"
                                                              StrokeLineJoin="Round" Width="22" Height="22" Stretch="Uniform"/>
                                                    </Button>
                                                </StackPanel>

                                                <Grid x:Name="BuilderGridHost"/>
                                            </StackPanel>

                                            <Button Content="APPLY TO OVERLAY"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,18,0,0"
                                                    Click="BuilderApply_Click"/>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="140"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="BuilderTemplateName"
                                                         Grid.Column="0"
                                                         Style="{StaticResource DarkEntry}"
                                                         Text=""/>
                                                <Button Grid.Column="2"
                                                        Content="SAVE AS CROSSHAIR"
                                                        Style="{StaticResource DarkBtn}"
                                                        Click="BuilderSaveTemplate_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <StackPanel x:Name="SettingsPanel" Margin="28,24,28,28" Visibility="Collapsed">

                                    <TextBlock Text="SETTINGS"
                                               FontFamily="{StaticResource BebasNeue}"
                                               FontSize="38"
                                               Foreground="#f5f5f5"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="General configuration"
                                               FontFamily="{StaticResource IBMPlexMono}"
                                               FontSize="10"
                                               Foreground="#787878"
                                               Margin="0,0,0,18"/>
                                    <Rectangle Height="1" Fill="#1e1e1e" Margin="0,0,0,18"/>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="GENERAL"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,14"/>
                                            <TextBlock Text="PROOF WINDOW KEY"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"/>
                                            <TextBlock Text="Hides the window from screen capture software"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"
                                                       Margin="0,3,0,8"/>
                                            <Button x:Name="ProofKeyBtn"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Click="ProofKeyBtn_Click"/>

                                            <TextBlock Text="PROFILE CYCLE KEY"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"
                                                       Margin="0,14,0,0"/>
                                            <TextBlock Text="Cycle through saved profiles without opening the UI"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"
                                                       Margin="0,3,0,8"/>
                                            <Button x:Name="CycleKeyBtn"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Click="CycleKeyBtn_Click"/>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="DISPLAY"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Choose which monitor the crosshair appears on"
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9" Foreground="#787878"
                                                       Margin="0,0,0,12"/>
                                            <StackPanel x:Name="MonitorPanel"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <StackPanel x:Name="SupportPanel" Margin="28,24,28,28" Visibility="Collapsed">

                                    <TextBlock Text="SUPPORT"
                                               FontFamily="{StaticResource BebasNeue}"
                                               FontSize="38"
                                               Foreground="#f5f5f5"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="If you enjoy CrosshairY, consider supporting the project"
                                               FontFamily="{StaticResource IBMPlexMono}"
                                               FontSize="10"
                                               Foreground="#787878"
                                               Margin="0,0,0,18"/>
                                    <Rectangle Height="1" Fill="#1e1e1e" Margin="0,0,0,18"/>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="SOCIALS"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,14"/>
                                            <Button Content="TWITTER / X"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,6"
                                                    Tag="https://x.com/julian_bzpass"
                                                    Click="SocialLink_Click"/>
                                            <Button Content="INSTAGRAM"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,6"
                                                    Tag="https://www.instagram.com/jxlian.ceisa/"
                                                    Click="SocialLink_Click"/>
                                            <Button Content="YOUTUBE"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,6"
                                                    Tag="https://www.youtube.com/@clientreviewer"
                                                    Click="SocialLink_Click"/>
                                            <Button Content="DISCORD"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Tag="https://discord.gg/tvJpwkyBmN"
                                                    Click="SocialLink_Click"/>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel Margin="18,16,18,18">
                                            <TextBlock Text="DONATE"
                                                       FontFamily="{StaticResource BebasNeue}"
                                                       FontSize="18"
                                                       Foreground="#f5f5f5"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="CrosshairY is free. Any support is appreciated."
                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                       FontSize="9"
                                                       Foreground="#787878"
                                                       Margin="0,0,0,14"/>
                                            <Button Content="SUPPORT CUTE PETS"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,6"
                                                    Tag="https://petcolove.org/"
                                                    Click="SocialLink_Click"/>
                                            <Button Content="CHECKOUT THIS PROJECT"
                                                    Style="{StaticResource DarkBtn}"
                                                    HorizontalAlignment="Stretch"
                                                    Tag="https://discord.gg/BcVjpCxNqC"
                                                    Click="SocialLink_Click"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                            </Grid>
                        </ScrollViewer>

                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="GoodbyeOverlay"
                    Panel.ZIndex="100"
                    Visibility="Collapsed"
                    Opacity="0"
                    Background="#080808">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="20,0,0,0">
                    <TextBlock x:Name="GoodbyeText"
                               Text="GOODBYE."
                               FontFamily="{StaticResource BebasNeue}"
                               FontSize="96"
                               Foreground="#f5f5f5"
                               HorizontalAlignment="Center"
                               Opacity="0"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <Rectangle x:Name="GoodbyeLine"
                               Height="1" Width="0"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0"
                               Fill="#f5f5f5"
                               Opacity="0.25"/>
                    <TextBlock x:Name="GoodbyeSubText"
                               Text="See you next time."
                               FontFamily="{StaticResource IBMPlexMono}"
                               FontSize="11"
                               Foreground="#787878"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0"
                               Opacity="0"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>

</Window>
