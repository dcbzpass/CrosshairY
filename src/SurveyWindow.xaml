<Window x:Class="CrosshairY.SurveyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="420"
        SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        RenderOptions.BitmapScalingMode="HighQuality"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Border Background="#080808"
            BorderBrush="#1e1e1e"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#080808"
                    BorderBrush="#1e1e1e"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="18,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="CrosshairY"
                                   FontFamily="{StaticResource IBMPlexMono}"
                                   FontSize="13"
                                   Foreground="#f5f5f5"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" — quick survey"
                                   FontFamily="{StaticResource IBMPlexMono}"
                                   FontSize="9"
                                   Foreground="#2a2a2a"
                                   VerticalAlignment="Center"
                                   Margin="10,1,0,0"/>
                    </StackPanel>
                    <Button Style="{StaticResource TitleCloseBtn}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,22,24,24">

                <TextBlock x:Name="QuestionLabel"
                           FontFamily="{StaticResource BebasNeue}"
                           FontSize="26"
                           Foreground="#f5f5f5"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>

                <TextBlock Text="select one option below"
                           FontFamily="{StaticResource IBMPlexMono}"
                           FontSize="9"
                           Foreground="#5a5a5a"
                           Margin="0,0,0,18"/>

                <Rectangle Height="1" Fill="#1e1e1e" Margin="0,0,0,18"/>

                <ItemsControl x:Name="OptionsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Tag="{Binding}"
                                    Style="{StaticResource SurveyOptionBtn}"
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Stretch"
                                    Click="Option_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Rectangle Height="1" Fill="#1e1e1e" Margin="0,12,0,18"/>

                <Button x:Name="SubmitBtn"
                        Content="SUBMIT"
                        Style="{StaticResource DarkBtn}"
                        HorizontalAlignment="Stretch"
                        IsEnabled="False"
                        Click="Submit_Click"/>

            </StackPanel>
        </Grid>
    </Border>

</Window>
